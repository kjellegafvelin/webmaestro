<dialogViews:DialogWindowBase x:Class="WebMaestro.Views.Dialogs.EnvironmentEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WebMaestro.ViewModels.Dialogs" 
        xmlns:converters="clr-namespace:WebMaestro.Converters"
        xmlns:dialogViews="clr-namespace:WebMaestro.Views.Dialogs"
        mc:Ignorable="d"
        x:Name="root"
        Title="Environments Editor" Height="680" Width="1024"
        d:DataContext="{d:DesignInstance {x:Type vm:EnvironmentEditorViewModel}}" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:NullToBooleanValueConverter x:Key="nullToBool"/>
        <converters:EnumMatchToBooleanConverter x:Key="enumMatchToBool" />
        <converters:EnumMatchToVisibilityConverter x:Key="enumMatchToVisibility" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#33000000" />
            <Setter Property="Padding" Value="12" />
            <!--<Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" />-->
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,4" />
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>
    <Grid Margin="24,25,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="49" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlockStyle}" Text="Edit Settings" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Environments" Style="{StaticResource SectionHeaderText}" />

                    <ListBox Grid.Row="1" ItemsSource="{Binding Environments}" SelectedItem="{Binding SelectedEnvironment}" MinHeight="200" x:Name="envList">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Margin="4,2" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="2" Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Name" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedEnvironment.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                    </Grid>

                    <UniformGrid Grid.Row="3" Rows="1" Columns="3" HorizontalAlignment="Stretch">
                        <Button Content="Add" Width="80" Command="{Binding AddEnvironmentCommand}" Margin="0,0,6,0" />
                        <Button Content="Clone" Width="80" Command="{Binding CloneEnvironmentCommand}" Margin="3,0" />
                        <Button Content="Remove" Width="80" Command="{Binding RemoveEnvironmentCommand}" Margin="6,0,0,0" />
                    </UniformGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="0,0,0,10" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Authentication" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,8" />
                            <WrapPanel>
                                <RadioButton GroupName="EnvironmentAuth" Content="None" Margin="0,0,16,0"
                                         IsChecked="{Binding Path=SelectedEnvironment.Authentication.Type, Mode=TwoWay, Converter={StaticResource enumMatchToBool}, ConverterParameter=None}" />
                                <RadioButton GroupName="EnvironmentAuth" Content="Basic" Margin="0,0,16,0"
                                         IsChecked="{Binding Path=SelectedEnvironment.Authentication.Type, Mode=TwoWay, Converter={StaticResource enumMatchToBool}, ConverterParameter=Basic}" />
                                <RadioButton GroupName="EnvironmentAuth" Content="Api Key" Margin="0,0,16,0"
                                         IsChecked="{Binding Path=SelectedEnvironment.Authentication.Type, Mode=TwoWay, Converter={StaticResource enumMatchToBool}, ConverterParameter=ApiKey}" />
                                <RadioButton GroupName="EnvironmentAuth" Content="Bearer Token"
                                         IsChecked="{Binding Path=SelectedEnvironment.Authentication.Type, Mode=TwoWay, Converter={StaticResource enumMatchToBool}, ConverterParameter=BearerToken}" />
                            </WrapPanel>
                        </StackPanel>

                        <Grid Margin="0,10,0,0" Grid.Row="1"
                          Visibility="{Binding SelectedEnvironment.Authentication.Type, Converter={StaticResource enumMatchToVisibility}, ConverterParameter=Basic}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="0,0,8,8">Username</TextBlock>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Path=SelectedEnvironment.Authentication.Username, Mode=TwoWay}" />

                            <TextBlock Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,0">Password</TextBlock>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Path=SelectedEnvironment.Authentication.Password, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,10,0,0" Grid.Row="1"
                          Visibility="{Binding SelectedEnvironment.Authentication.Type, Converter={StaticResource enumMatchToVisibility}, ConverterParameter=ApiKey}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="0,0,8,8">Key</TextBlock>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Path=SelectedEnvironment.Authentication.Key, Mode=TwoWay}" />

                            <TextBlock Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,8">Value</TextBlock>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Path=SelectedEnvironment.Authentication.Value, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" VerticalAlignment="Center" Margin="0,0,8,0">Set in</TextBlock>
                            <ComboBox Grid.Row="2" Grid.Column="1" SelectedValuePath="Tag" SelectedValue="{Binding Path=SelectedEnvironment.Authentication.ApiKeyLocation, Mode=TwoWay}">
                                <ComboBoxItem Tag="Header">Header</ComboBoxItem>
                                <ComboBoxItem Tag="Querystring">Querystring</ComboBoxItem>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,10,0,0" Grid.Row="1"
                          Visibility="{Binding SelectedEnvironment.Authentication.Type, Converter={StaticResource enumMatchToVisibility}, ConverterParameter=BearerToken}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="0,0,8,0">Token</TextBlock>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Path=SelectedEnvironment.Authentication.Token, Mode=TwoWay}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Variables" Style="{StaticResource SectionHeaderText}" />

                        <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedEnvironment.Variables}" SelectedItem="{Binding SelectedVariable, Mode=TwoWay}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="200" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="*" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="200" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Left">
                            <Button Content="Add Variable" Command="{Binding AddVariableCommand}" Width="150" />
                            <Button Content="Remove Variable" Command="{Binding RemoveVariableCommand}" Width="150" Margin="8,0,0,0" 
                                IsEnabled="{Binding SelectedVariable, Converter={StaticResource nullToBool}, ConverterParameter=true}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2" Text="{Binding ValidationMessage}" Foreground="#C42B1C" Margin="0,10,0,0" Visibility="{Binding IsValidationMessageVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

            </Grid>

        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="90" Margin="0,0,8,0" Command="{Binding OkCommand}" />
            <Button Content="Cancel" Width="90" Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</dialogViews:DialogWindowBase>
