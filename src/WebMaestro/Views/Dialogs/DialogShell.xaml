<UserControl x:Class="WebMaestro.Views.Dialogs.DialogShell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="clr-namespace:WebMaestro.Views.Dialogs"
             mc:Ignorable="d">
	<UserControl.Template>
		<ControlTemplate TargetType="{x:Type local:DialogShell}">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*" />
					<RowDefinition Height="80" />
				</Grid.RowDefinitions>
				<Border Grid.Row="0" Background="#2B2B2B">
					<Grid HorizontalAlignment="Stretch" Margin="24,25,24,24">
						<Grid.RowDefinitions>
							<RowDefinition Height="49" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>
						<TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding HeaderText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
						<ContentPresenter  Grid.Row="1"  />
					</Grid>
				</Border>
				<Grid Grid.Row="1" Margin="24,24,24,24">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="220"/>
						<ColumnDefinition Width="8" />
						<ColumnDefinition Width="220"/>
					</Grid.ColumnDefinitions>
					<Button Grid.Column="0" Name="btnOK" Content="OK" HorizontalAlignment="Center" VerticalAlignment="Top" IsDefault="True"
						Command="{Binding OkCommand}" Height="32" Width="220"/>
					<Button Grid.Column="2"  Content="Cancel" HorizontalAlignment="Center" VerticalAlignment="Top" IsCancel="True" Grid.ColumnSpan="2" Height="32" Width="220"/>
				</Grid>
			</Grid>
		</ControlTemplate>
	</UserControl.Template>
</UserControl>
