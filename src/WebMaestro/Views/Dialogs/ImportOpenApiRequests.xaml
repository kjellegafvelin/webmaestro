<dialogViews:DialogWindowBase x:Class="WebMaestro.Views.Dialogs.ImportOpenApiRequests"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="https://github.com/fantasticfiasco/mvvm-dialogs"
        xmlns:dialogs="clr-namespace:WebMaestro.ViewModels.Dialogs" xmlns:converters="clr-namespace:WebMaestro.Converters"
        xmlns:dialogViews="clr-namespace:WebMaestro.Views.Dialogs"
        md:DialogServiceViews.IsRegistered="True"
        d:DataContext="{d:DesignInstance Type=dialogs:ImportOpenApiRequestsViewModel}"
        mc:Ignorable="d"
        Title="Import Open API" Width="600" WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height">
    <Window.Resources>
        <ResourceDictionary>
            <converters:InverseBooleanConverter x:Key="inverseBool" />
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"></WindowChrome>
    </WindowChrome.WindowChrome>
    <Grid Margin="24,25,24,24">
        <StackPanel>
            <StackPanel>
                <TextBlock Text="Import Open API" Style="{StaticResource SubtitleTextBlockStyle}"/>
            </StackPanel>
            <StackPanel Margin="0,24,0,0">
                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,8">Select source to import from</TextBlock>
                <RadioButton GroupName="import" Content="Import from URL" IsChecked="{Binding IsUrl}"/>
                <TextBox Text="{Binding Url}" IsEnabled="{Binding IsUrl}" Margin="20,0,0,10" HorizontalAlignment="Stretch"/>
                <RadioButton GroupName="import" Content="Import from file"/>
                <Grid Margin="20,0,0,0" IsEnabled="{Binding IsUrl, Converter={StaticResource inverseBool}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Path}"/>
                    <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding BrowseForFileCommand}">...</Button>
                </Grid>
            </StackPanel>
            <StackPanel Margin="0,24,0,0">
                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,8">Location to save collection</TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Location}" />
                    <Button Grid.Column="1" Margin="8,0,0,0" ToolTip="Browse" Command="{Binding BrowseForFolderCommand}">...</Button>
                </Grid>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,48,0,0">
                <Button IsDefault="True" Command="{Binding OkCommand}" Width="80">OK</Button>
                <Button IsCancel="True" Margin="8,0,0,0" Width="80">Cancel</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</dialogViews:DialogWindowBase>
